{
  "name": "Bookmarks",
  "identifier": "com.wyattowalsh.iina-plugin-bookmarks",
  "version": "1.0.0",
  "description": "iina plugin for user-friendly media bookmark management that allows users to easily add, edit, and organize bookmarks within their media player.",
  "author": {
    "name": "Wyatt Walsh",
    "email": "wyattowalsh@gmail.com",
    "url": "https://w4w.dev"
  },
  "entry": "index.js",
  "ghRepo": "wyattowalsh/iina-plugin-bookmarks",
  "ghVersion": 1,
  "permissions": ["show-osd", "video-overlay", "file-system", "network-request"],
  "sidebarTab": {
    "name": "Bookmarks"
  },
  "preferencesPage": "preferences.html",
  "preferenceDefaults": {
    "autoSave": true,
    "showTimestamps": true,
    "defaultSortBy": "timestamp",
    "maxBookmarks": 1000,
    "autoReconcileFiles": true
  }
}
